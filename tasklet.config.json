* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

body {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
  background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
  min-height: 100vh;
  padding: 20px;
}

.dashboard {
  max-width: 1400px;
  margin: 0 auto;
  background: white;
  border-radius: 12px;
  box-shadow: 0 10px 40px rgba(0, 0, 0, 0.1);
  overflow: hidden;
}

/* Header */
.header {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  padding: 40px 30px;
  text-align: center;
}

.header h1 {
  font-size: 2.5em;
  margin-bottom: 10px;
  font-weight: 700;
}

.header p {
  font-size: 1.1em;
  opacity: 0.9;
  font-weight: 300;
}

/* Stats Grid */
.stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
  gap: 20px;
  padding: 30px;
  background: #f8f9fa;
  border-bottom: 1px solid #e9ecef;
}

.stat-card {
  background: white;
  padding: 20px;
  border-radius: 8px;
  box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  text-align: center;
  border-left: 4px solid #667eea;
}

.stat-card.gold {
  border-left-color: #ffc107;
  background: linear-gradient(135deg, #fff9e6 0%, #ffffff 100%);
}

.stat-card.silver {
  border-left-color: #c0c0c0;
  background: linear-gradient(135deg, #f5f5f5 0%, #ffffff 100%);
}

.stat-card.highlight {
  border-left-color: #28a745;
  background: linear-gradient(135deg, #e8f5e9 0%, #ffffff 100%);
}

.stat-label {
  font-size: 0.9em;
  color: #6c757d;
  margin-bottom: 10px;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.stat-value {
  font-size: 2em;
  font-weight: 700;
  color: #212529;
}

/* Controls */
.controls {
  display: flex;
  gap: 20px;
  padding: 20px 30px;
  background: #ffffff;
  align-items: center;
  flex-wrap: wrap;
  border-bottom: 1px solid #e9ecef;
}

.filter-group {
  display: flex;
  align-items: center;
  gap: 10px;
}

.filter-group label {
  font-weight: 600;
  color: #495057;
  font-size: 0.95em;
}

.filter-group select {
  padding: 8px 12px;
  border: 1px solid #dee2e6;
  border-radius: 4px;
  font-size: 0.95em;
  color: #495057;
  background-color: white;
  cursor: pointer;
  transition: border-color 0.2s;
}

.filter-group select:hover {
  border-color: #667eea;
}

.btn-primary {
  padding: 8px 16px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 600;
  transition: transform 0.2s, box-shadow 0.2s;
  font-size: 0.95em;
}

.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 4px 12px rgba(102, 126, 234, 0.4);
}

/* Deals Container */
.deals-container {
  display: grid;
  grid-template-columns: 1fr 1.2fr;
  gap: 0;
  min-height: 500px;
  background: white;
}

@media (max-width: 1024px) {
  .deals-container {
    grid-template-columns: 1fr;
  }

  .deal-details {
    border-top: 1px solid #e9ecef;
  }
}

/* Deals List */
.deals-list {
  border-right: 1px solid #e9ecef;
  overflow-y: auto;
  max-height: 600px;
}

.list-header {
  display: grid;
  grid-template-columns: 2fr 1fr 0.8fr 1.2fr 1fr;
  gap: 15px;
  padding: 15px 20px;
  background: #f8f9fa;
  font-weight: 600;
  font-size: 0.85em;
  text-transform: uppercase;
  color: #6c757d;
  border-bottom: 2px solid #dee2e6;
  position: sticky;
  top: 0;
}

.deal-item {
  display: grid;
  grid-template-columns: 2fr 1fr 0.8fr 1.2fr 1fr;
  gap: 15px;
  padding: 15px 20px;
  border-bottom: 1px solid #e9ecef;
  align-items: center;
  cursor: pointer;
  transition: background-color 0.2s;
}

.deal-item:hover {
  background-color: #f8f9fa;
}

.deal-item.selected {
  background-color: #e7f0ff;
  border-left: 4px solid #667eea;
  padding-left: 16px;
}

.deal-item.approved {
  background-color: #e8f5e9;
}

.deal-address {
  font-weight: 600;
  color: #212529;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.deal-city {
  font-size: 0.9em;
  color: #6c757d;
}

.deal-score {
  display: flex;
  justify-content: center;
}

.badge {
  padding: 4px 8px;
  border-radius: 4px;
  font-weight: 600;
  font-size: 0.85em;
  color: white;
}

.badge.tier-gold {
  background: #ffc107;
  color: #000;
}

.badge.tier-silver {
  background: #c0c0c0;
}

.badge.tier-bronze {
  background: #cd7f32;
}

.badge.tier-rejected {
  background: #dc3545;
}

.deal-profit {
  font-weight: 700;
  color: #28a745;
  text-align: right;
}

.btn-approve {
  padding: 6px 12px;
  background: #e9ecef;
  color: #495057;
  border: 1px solid #dee2e6;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 600;
  font-size: 0.85em;
  transition: all 0.2s;
  white-space: nowrap;
}

.btn-approve:hover {
  background: #667eea;
  color: white;
  border-color: #667eea;
}

.btn-approve.approved {
  background: #28a745;
  color: white;
  border-color: #28a745;
}

/* Deal Details */
.deal-details {
  padding: 30px;
  overflow-y: auto;
  max-height: 600px;
}

.deal-details h2 {
  font-size: 1.8em;
  color: #212529;
  margin-bottom: 15px;
  padding-bottom: 15px;
  border-bottom: 2px solid #667eea;
}

.detail-divider {
  height: 2px;
  background: linear-gradient(90deg, #667eea 0%, transparent 100%);
  margin: 20px 0;
}

.detail-section {
  margin-bottom: 25px;
}

.detail-section h3 {
  font-size: 1.1em;
  color: #495057;
  margin-bottom: 15px;
  display: flex;
  align-items: center;
  gap: 8px;
}

.detail-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 15px;
}

@media (max-width: 768px) {
  .detail-grid {
    grid-template-columns: 1fr;
  }
}

.detail-item {
  display: flex;
  flex-direction: column;
}

.detail-item.big {
  grid-column: 1 / -1;
  background: linear-gradient(135deg, #667eea15 0%, #764ba215 100%);
  padding: 15px;
  border-radius: 8px;
}

.detail-item .label {
  font-weight: 600;
  color: #6c757d;
  font-size: 0.9em;
  margin-bottom: 5px;
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.detail-item .value {
  font-size: 1.1em;
  color: #212529;
  font-weight: 500;
}

.detail-item .value.highlight {
  color: #667eea;
  font-weight: 700;
}

.detail-item .value.profit {
  color: #28a745;
  font-weight: 700;
  font-size: 1.3em;
}

/* Score Display */
.score-display {
  display: flex;
  gap: 20px;
  align-items: center;
  background: #f8f9fa;
  padding: 20px;
  border-radius: 8px;
}

.score-circle {
  width: 100px;
  height: 100px;
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-weight: 700;
  color: white;
  flex-shrink: 0;
}

.score-circle.tier-gold {
  background: linear-gradient(135deg, #ffc107 0%, #ff9800 100%);
}

.score-circle.tier-silver {
  background: linear-gradient(135deg, #c0c0c0 0%, #808080 100%);
}

.score-circle.tier-bronze {
  background: linear-gradient(135deg, #cd7f32 0%, #8b4513 100%);
}

.score-number {
  font-size: 2.5em;
}

.score-max {
  font-size: 0.8em;
  opacity: 0.8;
}

.score-info {
  flex: 1;
}

.tier-badge {
  display: inline-block;
  padding: 8px 12px;
  border-radius: 6px;
  font-weight: 600;
  margin-bottom: 10px;
  background: #f0f0f0;
}

.tier-badge.tier-gold {
  background: #fff3cd;
  color: #856404;
}

.tier-badge.tier-silver {
  background: #f0f0f0;
  color: #495057;
}

.tier-badge.tier-bronze {
  background: #fdeae6;
  color: #8b4513;
}

.tier-description {
  color: #6c757d;
  font-size: 0.95em;
  line-height: 1.4;
}

/* Approval Section */
.approval-section {
  margin-top: 25px;
  padding-top: 25px;
  border-top: 1px solid #e9ecef;
}

.btn-approve-large {
  width: 100%;
  padding: 15px;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 8px;
  cursor: pointer;
  font-weight: 700;
  font-size: 1.1em;
  transition: transform 0.2s, box-shadow 0.2s;
}

.btn-approve-large:hover {
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);
}

.btn-approve-large.approved {
  background: linear-gradient(135deg, #28a745 0%, #20c997 100%);
}

/* Summary Section */
.summary-section {
  padding: 30px;
  background: linear-gradient(135deg, #f8f9fa 0%, #ffffff 100%);
  border-top: 1px solid #e9ecef;
}

.summary-box {
  background: white;
  padding: 20px;
  border-radius: 8px;
  border-left: 4px solid #667eea;
}

.summary-box h3 {
  color: #212529;
  margin-bottom: 15px;
  font-size: 1.2em;
}

.summary-box p {
  color: #495057;
  margin: 8px 0;
  font-size: 0.95em;
}

.summary-box strong {
  color: #212529;
  font-weight: 700;
}

.summary-box .note {
  margin-top: 15px;
  padding-top: 15px;
  border-top: 1px solid #e9ecef;
  color: #28a745;
  font-weight: 600;
}

/* Scrollbar Styling */
::-webkit-scrollbar {
  width: 8px;
  height: 8px;
}

::-webkit-scrollbar-track {
  background: #f1f1f1;
}

::-webkit-scrollbar-thumb {
  background: #888;
  border-radius: 4px;
}

::-webkit-scrollbar-thumb:hover {
  background: #555;
}

/* Voice Calling Section */
.voice-section {
  background: linear-gradient(135deg, #667eea10 0%, #764ba210 100%);
  border: 2px solid #667eea;
}

.voice-card {
  padding: 1.5rem;
}

.voice-description {
  color: #666;
  margin-bottom: 1rem;
  font-size: 0.95rem;
}

.voice-buttons {
  display: flex;
  gap: 1rem;
  margin-bottom: 1rem;
}

.btn-call-large {
  flex: 1;
  padding: 1rem 1.5rem;
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: white;
  border: none;
  border-radius: 6px;
  font-size: 1rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-call-large:hover:not(:disabled) {
  transform: translateY(-2px);
  box-shadow: 0 8px 16px rgba(102, 126, 234, 0.3);
}

.btn-call-large:disabled,
.btn-call-large.loading {
  opacity: 0.6;
  cursor: not-allowed;
}

.btn-secondary {
  padding: 1rem 1.5rem;
  background: #f0f0f0;
  color: #333;
  border: none;
  border-radius: 6px;
  font-size: 0.95rem;
  font-weight: 600;
  cursor: pointer;
  transition: all 0.3s ease;
}

.btn-secondary:hover {
  background: #e0e0e0;
}

.call-history {
  margin-top: 1.5rem;
  padding-top: 1.5rem;
  border-top: 1px solid #ddd;
}

.call-history h4 {
  margin: 0 0 1rem 0;
  color: #333;
  font-size: 0.95rem;
}

.history-item {
  display: flex;
  gap: 0.75rem;
  padding: 0.75rem;
  background: white;
  border-radius: 4px;
  margin-bottom: 0.5rem;
  align-items: center;
  font-size: 0.9rem;
}

.call-date {
  color: #999;
  min-width: 90px;
}

.motivation-badge {
  padding: 0.25rem 0.5rem;
  border-radius: 3px;
  font-weight: 600;
  font-size: 0.85rem;
}

.motivation-high {
  background: #d4edda;
  color: #155724;
}

.motivation-medium {
  background: #fff3cd;
  color: #856404;
}

.motivation-low {
  background: #f8d7da;
  color: #721c24;
}

.motivation-none {
  background: #e2e3e5;
  color: #383d41;
}

.call-status {
  color: #666;
  margin-left: auto;
}

.call-price {
  color: #27ae60;
  font-weight: 600;
  margin-left: 0.5rem;
}

/* Print Styles */
@media print {
  .controls,
  .btn-approve,
  .btn-approve-large {
    display: none;
  }
}
