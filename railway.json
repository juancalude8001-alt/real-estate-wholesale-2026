{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "dockerfile"
  },
  "deploy": {
    "restartPolicyType": "on_failure",
    "restartPolicyMaxRetries": 5,
    "numReplicas": 1,
    "startCommand": "uvicorn dashboard_backend:app --host 0.0.0.0 --port $PORT"
  },
  "plugins": {
    "postgres": {
      "version": "15"
    }
  }
}
